# =============================================================================
# Oasis — Environment Variables
# Copy this file to .env and fill in your values
# All services listed here use FREE tiers or open-source self-hosted solutions
# =============================================================================

# ── LLM Provider (Primary: Gemini Pro — your subscription) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# ── LLM Fallback (Groq — free tier, 30 req/min) ────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Translation (Bhashini — free government API) ────────────────────────────
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_ULCA_API_KEY=your_ulca_api_key
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline

# ── Translation Fallback (Google Translate — free tier) ─────────────────────
GOOGLE_TRANSLATE_API_KEY=optional_google_translate_key

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ── Database (PostgreSQL — Docker, free) ────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=oasis
POSTGRES_USER=oasis_user
POSTGRES_PASSWORD=oasis_dev_password_change_me

# ── Cache (Redis — Docker, free) ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Vector Database (Qdrant — Docker, free) ─────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_PREFIX=oasis

# ── Object Storage (MinIO — Docker, S3-compatible, free) ────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=oasis_minio_access
MINIO_SECRET_KEY=oasis_minio_secret_change_me
MINIO_BUCKET_KNOWLEDGE=knowledge-base
MINIO_BUCKET_MODELS=ml-models
MINIO_BUCKET_AUDIO=audio-cache

# ── MCP Server Data Sources (Free APIs) ────────────────────────────────────
# IMD Weather API (register at api.imd.gov.in — free)
IMD_API_KEY=your_imd_api_key
IMD_API_URL=https://api.imd.gov.in

# OpenWeatherMap (free tier — 1000 calls/day)
OPENWEATHER_API_KEY=your_openweathermap_key

# OpenAQ (free, no key needed for basic access)
OPENAQ_API_URL=https://api.openaq.org/v2

# NDMA SACHET (RSS feed, no key needed)
NDMA_SACHET_RSS_URL=https://sachet.ndma.gov.in/cap_public_website/FetchLatestAlertDetails

# ── Notifications (Free tiers) ─────────────────────────────────────────────
# Firebase Cloud Messaging (free)
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id

# WhatsApp Business API (free for templates)
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Twilio SMS (free trial)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# Resend Email (free — 3K emails/month)
RESEND_API_KEY=your_resend_api_key

# ── Observability (All self-hosted, free) ──────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=oasis
GRAFANA_ADMIN_PASSWORD=admin

# ── Service URLs (internal Docker network) ──────────────────────────────────
GATEWAY_URL=http://gateway:8000
AUTH_SERVICE_URL=http://auth:8001
ORCHESTRATOR_URL=http://orchestrator:8002
RAG_ENGINE_URL=http://rag-engine:8003
TRANSLATION_URL=http://translation:8004
VOICE_SERVICE_URL=http://voice:8005
ACCESSIBILITY_URL=http://accessibility:8006
NOTIFICATION_URL=http://notification:8007
ML_PIPELINE_URL=http://ml-pipeline:8008

# ── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
