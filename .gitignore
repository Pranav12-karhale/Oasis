node_modules/
.next/
out/
.vercel

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

